{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 64
    },
    "tool": {
      "type": "string",
      "enum": ["ffmpeg", "ffprobe", "pandoc", "magick", "ocrmypdf", "whisper-cli", "gs", "soffice"]
    },
    "install_cmd": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3
        }
      ]
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "minItems": 1
      },
      "maxItems": 8,
      "minItems": 1
    },
    "output_path": { "type": "string", "minLength": 1 },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "size_under",
              "duration_matches",
              "streams_present",
              "plays",
              "audio_stream_present",
              "loudness_matches",
              "true_peak_under",
              "file_valid",
              "page_count_positive",
              "text_extractable",
              "format_matches",
              "srt_valid",
              "cue_count",
              "timestamps_monotonic"
            ]
          },
          "target": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        },
        "required": ["type", "target"],
        "additionalProperties": false
      }
    },
    "derivations": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "object",
          "properties": {
            "video_bitrate_kbps": {
              "type": "object",
              "properties": {
                "name": { "type": "string", "enum": ["size_target_video_bitrate"] },
                "args": {
                  "type": "object",
                  "properties": {
                    "target_bytes": { "type": "integer", "minimum": 1 },
                    "audio_kbps": { "type": "number", "exclusiveMinimum": 0 },
                    "safety_factor": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 }
                  },
                  "required": ["target_bytes", "audio_kbps", "safety_factor"],
                  "additionalProperties": false
                }
              },
              "required": ["name", "args"],
              "additionalProperties": false
            }
          },
          "required": ["video_bitrate_kbps"],
          "additionalProperties": false
        }
      ]
    },
    "intermediates": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 1,
          "maxItems": 8
        }
      ]
    },
    "resources": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["whisper-large-v3-turbo"]
          },
          "minItems": 1,
          "maxItems": 4
        }
      ]
    }
  },
  "required": ["name", "tool", "install_cmd", "commands", "output_path", "checks", "derivations", "intermediates", "resources"],
  "additionalProperties": false
}

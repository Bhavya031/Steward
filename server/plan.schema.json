{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "tool": {
      "type": "string",
      "enum": ["ffmpeg", "ffprobe", "pandoc", "magick", "ocrmypdf", "whisper-cli", "gs", "soffice"]
    },
    "install_cmd": {
      "anyOf": [
        { "type": "null" },
        {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3
        }
      ]
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "minItems": 1
      },
      "maxItems": 8,
      "minItems": 1
    },
    "output_path": { "type": "string", "minLength": 1 },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "size_under",
              "duration_matches",
              "streams_present",
              "plays"
            ]
          },
          "target": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "boolean" }
            ]
          }
        },
        "required": ["type", "target"],
        "additionalProperties": false
      }
    }
  },
  "required": ["tool", "install_cmd", "commands", "output_path", "checks"],
  "additionalProperties": false
}

{
  "name": "compress-video-under-25mb",
  "replaced_service": "Video compressor SaaS",
  "monthly_price": 12,
  "command_template": {
    "commands": [
      [
        "ffmpeg",
        "-i", "{{input_0}}",
        "-map", "0:v:0",
        "-c:v", "libx264",
        "-preset", "slow",
        "-b:v", "{{video_bitrate_kbps}}",
        "-pass", "1",
        "-passlogfile", "{{temp_dir}}/ffmpeg2pass",
        "-an",
        "-f", "null",
        "{{temp_dir}}/pass1.null"
      ],
      [
        "ffmpeg",
        "-i", "{{input_0}}",
        "-map", "0:v:0",
        "-map", "0:a:0",
        "-c:v", "libx264",
        "-preset", "slow",
        "-b:v", "{{video_bitrate_kbps}}",
        "-pass", "2",
        "-passlogfile", "{{temp_dir}}/ffmpeg2pass",
        "-c:a", "aac",
        "-b:a", "96k",
        "-movflags", "+faststart",
        "{{input_0_dir}}/{{input_0_stem}}-compressed.mp4"
      ]
    ],
    "output_path": "{{input_0_dir}}/{{input_0_stem}}-compressed.mp4"
  },
  "checks": [
    {
      "type": "size_under",
      "target": 25000000
    },
    {
      "type": "duration_matches",
      "target": "{{input_0}}"
    },
    {
      "type": "streams_present",
      "target": "video,audio"
    },
    {
      "type": "plays",
      "target": true
    }
  ],
  "created_at": "2026-07-15T10:46:24.692Z",
  "arch": "arm64",
  "tool": "ffmpeg",
  "install_weight": "light"
}

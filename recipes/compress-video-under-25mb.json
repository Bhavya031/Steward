{
  "name": "compress-video-under-25mb",
  "replaced_service": "Video compressor SaaS",
  "monthly_price": 12,
  "command_template": {
    "commands": [
      [
        "ffmpeg",
        "-i",
        "{{input_0}}",
        "-map",
        "0:v:0",
        "-map",
        "0:a:0",
        "-c:v",
        "libx264",
        "-b:v",
        "{{video_bitrate_kbps}}",
        "-maxrate",
        "{{video_bitrate_kbps}}",
        "-bufsize",
        "1000k",
        "-c:a",
        "aac",
        "-b:a",
        "96k",
        "-movflags",
        "+faststart",
        "{{input_0_dir}}/{{input_0_stem}}-under-25mb-repaired.mp4"
      ]
    ],
    "output_path": "{{input_0_dir}}/{{input_0_stem}}-under-25mb-repaired.mp4"
  },
  "checks": [
    {
      "type": "size_under",
      "target": 25000000
    },
    {
      "type": "duration_matches",
      "target": "{{input_0}}"
    },
    {
      "type": "streams_present",
      "target": "video,audio"
    },
    {
      "type": "plays",
      "target": true
    }
  ],
  "created_at": "2026-07-15T20:00:42.718Z",
  "arch": "arm64",
  "tool": "ffmpeg",
  "install_weight": "light",
  "derivations": {
    "video_bitrate_kbps": {
      "name": "size_target_video_bitrate",
      "args": {
        "target_bytes": 25000000,
        "audio_kbps": 96,
        "safety_factor": 0.94
      }
    }
  }
}

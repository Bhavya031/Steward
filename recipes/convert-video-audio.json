{
  "name": "convert-video-audio",
  "replaced_service": "CloudConvert",
  "monthly_price": 9,
  "command_template": {
    "commands": [
      [
        "ffmpeg",
        "-i",
        "{{input_0}}",
        "{{media_args}}",
        "{{input_0_dir}}/{{input_0_stem}}.{{target_format}}"
      ]
    ],
    "output_path": "{{input_0_dir}}/{{input_0_stem}}.{{target_format}}"
  },
